<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aim.nats-server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/nats-server</string>
        <string>-c</string>
        <string>/Users/yangzs/.aim/server/nats.conf</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>ThrottleInterval</key>
        <integer>10</integer>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/yangzs/.aim/server</string>
    <key>StandardOutPath</key>
    <string>/Users/yangzs/.aim/logs/nats-server.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yangzs/.aim/logs/nats-server.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
