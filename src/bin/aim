#!/usr/bin/env python3
"""AIM CLI — 统一命令行入口

用法:
  aim watch [--agent ZS0002] [--history 10]
  aim observe [--agent ZS0002] [--history 10]
  aim send --grp grp_trio --text "hello"
  aim send --to ZS0001 --text "hello"
  
环境变量:
  AIM_AGENT_ID    Agent ID (默认: 从 config 读取)
"""

import sys
import os
from pathlib import Path

# SDK 路径
SDK_DIR = Path.home() / ".aim" / "bin"
if str(SDK_DIR) not in sys.path:
    sys.path.insert(0, str(SDK_DIR))


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "watch":
        import importlib.util
        spec = importlib.util.spec_from_file_location("aim_watch",
            os.path.join(SDK_DIR, "aim-watch.py"))
        mod = importlib.util.module_from_spec(spec)
        sys.modules["aim_watch"] = mod
        spec.loader.exec_module(mod)
        sys.argv = ["aim-watch"] + args
        mod.main()

    elif cmd == "observe":
        import importlib.util
        spec = importlib.util.spec_from_file_location("aim_observe",
            os.path.join(SDK_DIR, "aim-observe.py"))
        mod = importlib.util.module_from_spec(spec)
        sys.modules["aim_observe"] = mod
        spec.loader.exec_module(mod)
        sys.argv = ["aim-observe"] + args
        mod.main()

    elif cmd == "send":
        import importlib.util
        spec = importlib.util.spec_from_file_location("aim_send",
            os.path.join(SDK_DIR, "aim_send.py"))
        mod = importlib.util.module_from_spec(spec)
        sys.modules["aim_send"] = mod
        spec.loader.exec_module(mod)
        sys.argv = ["aim-send"] + args
        mod.main()

    else:
        print(f"未知命令: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
