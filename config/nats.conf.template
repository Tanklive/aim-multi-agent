# AIM NATS Server 配置文件
# 版本：v2.0
# 日期：2026-06-09
# 说明：迁移到独立目录 ~/aim-server/

# 服务器配置
host: 0.0.0.0
port: 4222

# JetStream 配置
jetstream {
  store_dir: "/Users/yangzs/aim-server/data/jetstream"
  max_mem: 1G
  max_file: 10G
}

# 日志配置
log_file: "/Users/yangzs/aim-server/logs/nats-server.log"
logtime: true
debug: false
trace: false

# 连接配置
max_connections: 100
max_payload: 1MB
max_pending: 10MB

# 心跳配置
ping_interval: 10s

