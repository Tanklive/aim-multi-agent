#!/usr/bin/env python3
"""
AIM — 标准 Agent 通讯客户端统一入口

用法：
  aim register [--server ws://...] [--name "Agent名"] [--framework openclaw]
  aim agent start --id ZS0003 --handler ~/handler.sh
  aim agent stop --id ZS0003
  aim send ZS0002 "你好" [--from ZS0003] [--group]
  aim watch [--from ZS0001] [--grep "关键词"]
  aim status [--id ZS0003]
  aim history [--limit 10]
  aim health

设计文档：~/shared/aim/aim-client-final-plan.md
"""

import argparse
import asyncio
import json
import os
import signal
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

# ── 路径设置 ─────────────────────────

AIM_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(AIM_DIR))

# ── 配置加载 ─────────────────────────

def get_config() -> dict:
    """加载 AIM 配置（环境变量 > 配置文件 > 默认值）"""
    config = {}

    # 配置文件优先级
    config_paths = [
        Path("~/.hermes/aim/config.json").expanduser(),
        AIM_DIR / "config.json",
        Path("~/.aim/config.json").expanduser(),
    ]
    for p in config_paths:
        if p.exists():
            try:
                with open(p) as f:
                    cfg = json.load(f)
                    config["server"] = cfg.get("domain", "ws://127.0.0.1:18900")
                    if config["server"] and not config["server"].startswith(("ws://", "wss://")):
                        config["server"] = f"ws://{config['server']}:18900"
                    config["agent_id"] = cfg.get("node_id", "")
                    # 读取 secret
                    secret_file = AIM_DIR / "secrets" / f"{config.get('agent_id', '')}.secret"
                    if secret_file.exists():
                        config["secret"] = secret_file.read_text().strip()
                    # 读取 agent 配置目录
                    agent_dir = Path.home() / ".aim" / f"agent-{config.get('agent_id', '')}"
                    if agent_dir.exists():
                        config["agent_dir"] = str(agent_dir)
                        handler = agent_dir / "handler.sh"
                        if handler.exists():
                            config["handler"] = str(handler)
            except Exception:
                pass
            break

    # 环境变量覆盖
    config["server"] = os.environ.get("AIM_SERVER_URL", config.get("server", "ws://127.0.0.1:18900"))
    config["agent_id"] = os.environ.get("AIM_AGENT_ID", config.get("agent_id", ""))
    config["secret"] = os.environ.get("AIM_SECRET", config.get("secret", ""))
    config["handler"] = os.environ.get("AIM_HANDLER", config.get("handler", ""))

    return config


def get_agent_dir(agent_id: str) -> Path:
    """获取 Agent 独立目录"""
    return Path.home() / ".aim" / f"agent-{agent_id}"


def ensure_agent_dir(agent_id: str) -> Path:
    """确保 Agent 目录存在"""
    d = get_agent_dir(agent_id)
    (d / "secrets").mkdir(parents=True, exist_ok=True)
    (d / "logs").mkdir(parents=True, exist_ok=True)
    return d


# ── 子命令：register ──────────────────

def cmd_register(args):
    """注册 Agent 到 AIM Hub"""
    # 委托给 register_agent.py
    register_script = AIM_DIR / "register_agent.py"
    if not register_script.exists():
        print("❌ register_agent.py 不存在")
        return 1

    cmd = [sys.executable, str(register_script), "register"]
    if args.force:
        cmd.append("--force")
    if args.dry_run:
        cmd.append("--dry-run")

    result = subprocess.run(cmd, capture_output=False)
    return result.returncode


def cmd_register_init(args):
    """初始化 Agent 配置模板"""
    register_script = AIM_DIR / "register_agent.py"
    if not register_script.exists():
        print("❌ register_agent.py 不存在")
        return 1

    cmd = [sys.executable, str(register_script), "init",
           "--name", args.name,
           "--framework", args.framework,
           "--operator", args.operator]
    if args.emoji:
        cmd.extend(["--emoji", args.emoji])

    result = subprocess.run(cmd, capture_output=False)
    return result.returncode


# ── 子命令：agent start/stop ──────────

def cmd_agent_start(args):
    """启动 Agent 守护进程"""
    agent_id = args.id
    handler = args.handler
    config = get_config()

    # 确保目录存在
    agent_dir = ensure_agent_dir(agent_id)

    # 验证 handler 存在
    if handler:
        handler_path = Path(handler).expanduser()
        if not handler_path.exists():
            print(f"❌ handler 脚本不存在: {handler_path}")
            return 1
        if not os.access(handler_path, os.X_OK):
            print(f"⚠️  handler 脚本无执行权限，正在添加...")
            handler_path.chmod(0o755)

    # 检查是否已运行
    pid_file = agent_dir / "agent.pid"
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)  # 检查进程是否存在
            print(f"⚠️  Agent {agent_id} 已在运行 (PID {pid})")
            print(f"   使用 `aim agent stop --id {agent_id}` 先停止")
            return 1
        except (ProcessLookupError, ValueError):
            # 进程已死，清理 pid 文件
            pid_file.unlink()

    # 构造启动命令
    agent_script = AIM_DIR / "aim-agent.py"
    if not agent_script.exists():
        print("❌ aim-agent.py 不存在")
        return 1

    # 设置环境变量
    env = os.environ.copy()
    env["AIM_AGENT_ID"] = agent_id
    if handler:
        env["AIM_HANDLER"] = str(Path(handler).expanduser())
    if config.get("server"):
        env["AIM_SERVER_URL"] = config["server"]

    # 启动守护进程
    log_file = agent_dir / "logs" / "agent.log"
    log_file.parent.mkdir(parents=True, exist_ok=True)

    print(f"🚀 启动 Agent {agent_id}...")
    print(f"   Server: {config.get('server', 'default')}")
    print(f"   Handler: {handler or 'default'}")
    print(f"   日志: {log_file}")

    # 使用 nohup 后台启动
    with open(log_file, "a") as lf:
        proc = subprocess.Popen(
            [sys.executable, str(agent_script)],
            env=env,
            stdout=lf,
            stderr=subprocess.STDOUT,
            start_new_session=True,  # 脱离终端
        )

    # 写 PID 文件
    pid_file.write_text(str(proc.pid))
    time.sleep(1)

    # 验证启动
    try:
        os.kill(proc.pid, 0)
        print(f"✅ Agent {agent_id} 已启动 (PID {proc.pid})")
        return 0
    except ProcessLookupError:
        print(f"❌ Agent 启动失败，检查日志: {log_file}")
        return 1


def cmd_agent_stop(args):
    """停止 Agent 守护进程"""
    agent_id = args.id
    agent_dir = get_agent_dir(agent_id)
    pid_file = agent_dir / "agent.pid"

    if not pid_file.exists():
        print(f"⚠️  Agent {agent_id} 未运行（无 PID 文件）")
        return 0

    try:
        pid = int(pid_file.read_text().strip())
    except ValueError:
        print("❌ PID 文件损坏")
        pid_file.unlink()
        return 1

    try:
        os.kill(pid, signal.SIGTERM)
        print(f"🔄 正在停止 Agent {agent_id} (PID {pid})...")

        # 等待进程退出（最多 10 秒）
        for _ in range(20):
            try:
                os.kill(pid, 0)
                time.sleep(0.5)
            except ProcessLookupError:
                break
        else:
            # 超时，强制 kill
            try:
                os.kill(pid, signal.SIGKILL)
                print(f"⚠️  强制终止 (SIGKILL)")
            except ProcessLookupError:
                pass

        pid_file.unlink(missing_ok=True)
        print(f"✅ Agent {agent_id} 已停止")
        return 0

    except ProcessLookupError:
        print(f"⚠️  进程 {pid} 已不存在，清理 PID 文件")
        pid_file.unlink(missing_ok=True)
        return 0


def cmd_agent_restart(args):
    """重启 Agent 守护进程"""
    cmd_agent_stop(args)
    time.sleep(1)
    return cmd_agent_start(args)


# ── 子命令：send ──────────────────────

def cmd_send(args):
    """发送消息"""
    aim_cli = AIM_DIR / "aim_cli.py"
    if not aim_cli.exists():
        print("❌ aim_cli.py 不存在")
        return 1

    cmd = [sys.executable, str(aim_cli), "send",
           "--to", args.to, "--msg", args.msg]
    if args.group:
        cmd.extend(["--group", args.group])

    result = subprocess.run(cmd, capture_output=False)
    return result.returncode


# ── 子命令：watch ─────────────────────

def cmd_watch(args):
    """实时监听消息"""
    aim_cli = AIM_DIR / "aim_cli.py"
    if not aim_cli.exists():
        print("❌ aim_cli.py 不存在")
        return 1

    cmd = [sys.executable, str(aim_cli), "watch"]
    if args.from_filter:
        cmd.extend(["--from", args.from_filter])
    if args.to_filter:
        cmd.extend(["--to", args.to_filter])
    if args.grep:
        cmd.extend(["--grep", args.grep])
    if args.json_output:
        cmd.append("--json")

    try:
        result = subprocess.run(cmd, capture_output=False)
        return result.returncode
    except KeyboardInterrupt:
        return 0


# ── 子命令：status ────────────────────

def cmd_status(args):
    """查看状态"""
    config = get_config()
    agent_id = args.id or config.get("agent_id", "")
    agent_dir = get_agent_dir(agent_id) if agent_id else None

    print(f"{'─' * 50}")
    print(f"  AIM Agent 状态")
    print(f"{'─' * 50}")
    print(f"  Agent ID:  {agent_id or '未配置'}")
    print(f"  Server:    {config.get('server', '未配置')}")
    print(f"  认证方式:  {'HMAC' if config.get('secret') else '无'}")

    # 检查进程状态
    if agent_dir and (agent_dir / "agent.pid").exists():
        try:
            pid = int((agent_dir / "agent.pid").read_text().strip())
            os.kill(pid, 0)
            print(f"  进程状态:  ✅ 运行中 (PID {pid})")
        except (ProcessLookupError, ValueError):
            print(f"  进程状态:  ❌ 已停止（PID 文件残留）")
    else:
        print(f"  进程状态:  ⚪ 未启动")

    # 检查 handler
    handler = config.get("handler", "")
    if handler:
        h_path = Path(handler)
        exists = h_path.exists()
        print(f"  Handler:   {'✅' if exists else '❌'} {handler}")
    else:
        print(f"  Handler:   ⚪ 未配置")

    print(f"{'─' * 50}")

    # 远程状态（可选）
    if args.remote:
        aim_cli = AIM_DIR / "aim_cli.py"
        if aim_cli.exists():
            subprocess.run([sys.executable, str(aim_cli), "status"])

    return 0


# ── 子命令：health ────────────────────

def cmd_health(args):
    """健康检查"""
    config = get_config()
    checks = []

    # 1. 配置文件
    checks.append(("配置文件", config.get("agent_id") != ""))

    # 2. 密钥文件
    secret_file = AIM_DIR / "secrets" / f"{config.get('agent_id', '')}.secret"
    checks.append(("密钥文件", secret_file.exists()))

    # 3. AIM Server 连通性
    try:
        import socket
        from urllib.parse import urlparse
        server = config.get("server", "")
        if server:
            parsed = urlparse(server)
            host = parsed.hostname or "127.0.0.1"
            port = parsed.port or 18900
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            result = sock.connect_ex((host, port))
            sock.close()
            checks.append(("AIM Server", result == 0))
        else:
            checks.append(("AIM Server", False))
    except Exception:
        checks.append(("AIM Server", False))

    # 4. Agent 进程
    agent_dir = get_agent_dir(config.get("agent_id", ""))
    pid_file = agent_dir / "agent.pid"
    running = False
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)
            running = True
        except (ProcessLookupError, ValueError):
            pass
    checks.append(("Agent 进程", running))

    # 输出
    all_ok = all(ok for _, ok in checks)
    print(f"\n{'─' * 40}")
    print(f"  AIM 健康检查 — {'✅ 全部正常' if all_ok else '⚠️ 有问题'}")
    print(f"{'─' * 40}")
    for name, ok in checks:
        print(f"  {'✅' if ok else '❌'} {name}")
    print(f"{'─' * 40}\n")

    return 0 if all_ok else 1


# ── 子命令：history ───────────────────

def cmd_history(args):
    """查看历史消息"""
    aim_cli = AIM_DIR / "aim_cli.py"
    if not aim_cli.exists():
        print("❌ aim_cli.py 不存在")
        return 1

    cmd = [sys.executable, str(aim_cli), "history",
           "--limit", str(args.limit)]

    result = subprocess.run(cmd, capture_output=False)
    return result.returncode


# ── 子命令：observer ──────────────────

def cmd_observer(args):
    """Observer 模式"""
    aim_cli = AIM_DIR / "aim_cli.py"
    if not aim_cli.exists():
        print("❌ aim_cli.py 不存在")
        return 1

    cmd = [sys.executable, str(aim_cli), "observer", args.target]
    if args.verbose:
        cmd.append("--verbose")

    try:
        result = subprocess.run(cmd, capture_output=False)
        return result.returncode
    except KeyboardInterrupt:
        return 0


# ── CLI 解析 ──────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="aim",
        description="AIM — 标准 Agent 通讯客户端",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  aim register --name "我的Agent" --framework openclaw
  aim agent start --id ZS0003 --handler ~/handler.sh
  aim agent stop --id ZS0003
  aim send ZS0002 "你好"
  aim watch
  aim status
  aim health

环境变量:
  AIM_SERVER_URL   Server 地址 (默认: ws://127.0.0.1:18900)
  AIM_AGENT_ID     Agent ID
  AIM_SECRET       HMAC 认证密钥
  AIM_HANDLER      Handler 脚本路径
        """
    )

    sub = parser.add_subparsers(dest="command", help="子命令")

    # ── register ──
    p_reg = sub.add_parser("register", help="注册 Agent 到 Hub")
    p_reg.add_argument("--server", help="Hub 地址")
    p_reg.add_argument("--name", help="Agent 名称")
    p_reg.add_argument("--framework", help="框架 (openclaw/hermes/crewai/...)")
    p_reg.add_argument("--operator", default="OP0001", help="操作人 ID")
    p_reg.add_argument("--emoji", help="Emoji 标识")
    p_reg.add_argument("--force", action="store_true", help="强制重新注册")
    p_reg.add_argument("--dry-run", action="store_true", help="仅校验不注册")

    # ── agent start/stop/restart ──
    p_agent = sub.add_parser("agent", help="Agent 进程管理")
    agent_sub = p_agent.add_subparsers(dest="agent_cmd", help="操作")

    p_start = agent_sub.add_parser("start", help="启动 Agent")
    p_start.add_argument("--id", required=True, help="Agent ID")
    p_start.add_argument("--handler", help="Handler 脚本路径")

    p_stop = agent_sub.add_parser("stop", help="停止 Agent")
    p_stop.add_argument("--id", required=True, help="Agent ID")

    p_restart = agent_sub.add_parser("restart", help="重启 Agent")
    p_restart.add_argument("--id", required=True, help="Agent ID")
    p_restart.add_argument("--handler", help="Handler 脚本路径")

    # ── send ──
    p_send = sub.add_parser("send", help="发送消息")
    p_send.add_argument("to", help="接收方 Agent ID")
    p_send.add_argument("msg", help="消息内容")
    p_send.add_argument("--from", dest="from_id", help="发送方 ID")
    p_send.add_argument("--group", help="群组名")

    # ── watch ──
    p_watch = sub.add_parser("watch", help="实时监听消息")
    p_watch.add_argument("--from", dest="from_filter", help="只显示指定发送方")
    p_watch.add_argument("--to", dest="to_filter", help="只显示指定接收方")
    p_watch.add_argument("--grep", help="内容过滤关键词")
    p_watch.add_argument("--json", dest="json_output", action="store_true", help="JSON 格式输出")

    # ── status ──
    p_status = sub.add_parser("status", help="查看状态")
    p_status.add_argument("--id", help="Agent ID")
    p_status.add_argument("--remote", action="store_true", help="同时查询远程状态")

    # ── health ──
    sub.add_parser("health", help="健康检查")

    # ── history ──
    p_hist = sub.add_parser("history", help="查看历史消息")
    p_hist.add_argument("--limit", type=int, default=10, help="条数 (默认: 10)")

    # ── observer ──
    p_obs = sub.add_parser("observer", help="Observer 实时观察")
    p_obs.add_argument("target", help="目标 Agent ID")
    p_obs.add_argument("--verbose", "-v", action="store_true", help="详细输出")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 1

    # 路由
    cmd_map = {
        "register": cmd_register,
        "agent": _dispatch_agent,
        "send": cmd_send,
        "watch": cmd_watch,
        "status": cmd_status,
        "health": cmd_health,
        "history": cmd_history,
        "observer": cmd_observer,
    }

    handler = cmd_map.get(args.command)
    if handler:
        return handler(args)
    else:
        parser.print_help()
        return 1


def _dispatch_agent(args):
    """路由 agent 子命令"""
    if not hasattr(args, "agent_cmd") or not args.agent_cmd:
        print("用法: aim agent {start|stop|restart} --id ZS0003")
        return 1

    agent_cmd_map = {
        "start": cmd_agent_start,
        "stop": cmd_agent_stop,
        "restart": cmd_agent_restart,
    }

    handler = agent_cmd_map.get(args.agent_cmd)
    if handler:
        return handler(args)
    else:
        print(f"未知命令: aim agent {args.agent_cmd}")
        return 1


if __name__ == "__main__":
    sys.exit(main())
