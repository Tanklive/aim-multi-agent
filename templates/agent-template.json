{
  "_schema": "aim-agent-config/1.0",
  "_description": "AIM Agent 标准配置文件。所有字段除 framework_cfg 外均为基础框架通用。",
  "agent_id": "$AGENT_ID",
  "agent_name": "$AGENT_NAME",
  "protocol_version": "",
  "version": "1.5.0",
  "nats_server": "nats://127.0.0.1:4222",
  "creds_path": "~/.aim/agents/$AGENT_ID/aim.creds",
  "framework": "$FRAMEWORK",
  "execution_model": "$EXECUTION_MODEL",
  "adapter_cmd": "~/.aim/agents/$AGENT_ID/adapter.sh",
  "adapter_timeout": 300,
  "framework_cfg": {},
  "mention_names": [
    "$AGENT_ID",
    "$AGENT_NAME"
  ],
  "security": {
    "allowlist": [
      "ZS0001",
      "ZS0002",
      "ZS0003"
    ],
    "allow_grp": [
      "grp_trio"
    ]
  },
  "heartbeat": {
    "interval_ms": 30000,
    "timeout_ms": 120000
  },
  "launchd": {
    "auto_manage": true,
    "keep_alive": true
  },
  "healthd": {
    "auto_ensure": true,
    "check_interval_s": 30
  },
  "notification": {
    "channel": [
      "file",
      "system_event"
    ],
    "watch_interval_s": 5
  },
  "log": {
    "level": "info"
  },
  "queue": {
    "max_age_ms": 3600000,
    "ack_timeout_ms": 300000,
    "capacity": 1000,
    "max_retries": 3
  },
  "queue_persist_path": "~/.aim/agents/$AGENT_ID/queue.jsonl",
  "queue_processor": {
    "enabled": true,
    "poll_interval_s": 1
  },
  "max_msg_age_sec": 900,
  "stall_watchdog_sec": 60,
  "grp_reply_cooldown_sec": 30,
  "_note_protocol": "protocol_version: \"\" = legacy CLI args (默认安全). 设 \"1.0\" 前确认 adapter.sh 支持 JSON stdin."
}