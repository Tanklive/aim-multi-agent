{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AIM Agent Config Schema v3",
  "description": "AIM Agent 配置 schema，新增 adapter 相关字段",
  "type": "object",
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "AIM Agent 全局 ID",
      "examples": ["ZS0001", "ZS0002", "ZS0003"]
    },
    "framework": {
      "type": "string",
      "description": "Agent 框架类型",
      "enum": ["openclaw", "hermes", "letta"],
      "examples": ["openclaw", "hermes", "letta"]
    },
    "adapter_cmd": {
      "type": "string",
      "description": "adapter.sh 绝对路径",
      "examples": [
        "~/.aim/adapters/openclaw/adapter.sh",
        "~/.aim/adapters/hermes/adapter.sh",
        "~/.aim/adapters/letta/adapter.sh"
      ]
    },
    "adapter_timeout": {
      "type": "integer",
      "description": "adapter 调用超时秒数",
      "default": 120,
      "minimum": 10,
      "maximum": 600
    },
    "nats_url": {
      "type": "string",
      "description": "NATS 服务器地址",
      "default": "nats://127.0.0.1:4222"
    },
    "credentials": {
      "type": "string",
      "description": "JWT credentials 文件路径",
      "examples": ["~/.aim/agents/ZS0002/aim.creds"]
    },
    "letta_agent_id": {
      "type": "string",
      "description": "Letta Agent 本地 ID（仅 framework=letta 时需要）",
      "examples": ["agent-local-6a723c52-5840-40c6-8fde-0f7a795dddff"]
    },
    "queue_dir": {
      "type": "string",
      "description": "降级文件队列目录（仅 V2 兼容时使用）",
      "default": "~/.aim/agents/{agent_id}/queue"
    },
    "reply_dir": {
      "type": "string",
      "description": "降级回复文件目录（仅 V2 兼容时使用）",
      "default": "~/.aim/agents/{agent_id}/replies"
    }
  },
  "required": ["agent_id", "framework", "adapter_cmd", "nats_url"]
}
